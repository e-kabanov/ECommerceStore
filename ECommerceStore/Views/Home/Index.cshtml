@model ECommerceStore.DTOs.ProductDisplayModel
@{
    ViewData["Title"] = "Каталог товаров";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="my-2">
    <form asp-action="Index" method="get" class="row row-cols-lg-auto g-3 align-items-center">
        <div class="col-12">
            <label class="visually-hidden" for="searchTerm">Поиск по названию</label>
            <div class="input-group">
                <input type="text" class="form-control" value="@Model.SearchTerm" id="searchTerm" name="searchTerm" placeholder="Поиск по названию товара" style="min-width: 300px;">
                <button type="submit" class="btn btn-primary">Найти</button>
                <a href="/Home/Index" class="btn btn-secondary">Сбросить</a>
            </div>
        </div>
    </form>
</div>

<div class="w-100 mt-4 d-flex flex-wrap justify-content-start">
    @if (Model.Products.Any())
    {
        @foreach (var product in Model.Products)
        {
            <div class="card mx-3 mb-4" style="width: 14rem;">
                @if (string.IsNullOrEmpty(product.Photo))
                {
                    <img style="width:100%; height:200px; object-fit:cover;" src="/images/NoImage.png" class="card-img-top" alt="Нет фото">
                }
                else
                {
                    <img style="width:100%; height:200px; object-fit:cover;" src="@product.Photo" class="card-img-top" alt="@product.Name">
                }
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@product.Name</h5>
                    <p class="card-text flex-grow-1">
                        @if (!string.IsNullOrEmpty(product.Description) && product.Description.Length > 100)
                        {
                            <small>@product.Description.Substring(0, 100)...</small>
                        }
                        else
                        {
                            <small>@product.Description</small>
                        }
                    </p>
                    <p class="card-text">
                        <strong>Цена:</strong> @product.Price.ToString("C")<br />
                        <strong>В наличии:</strong> @product.Stock шт.
                    </p>
                    @if (product.Stock > 0)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-auto">
                            <input type="hidden" name="productId" value="@product.ProductId" />
                            <input type="hidden" name="quantity" value="1" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn btn-primary w-100">
                                Добавить в корзину
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="text-danger fw-bold text-center mt-auto" style="border:1px solid red; padding:5px; border-radius:5px;">
                            Нет в наличии
                        </span>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info w-100 text-center">
            Товары не найдены. Попробуйте изменить параметры поиска.
        </div>
    }
</div>

